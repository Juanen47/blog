---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        <div class="post-header">
          <div class="post-date">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="updated">· Actualizado: <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1>{title}</h1>
          <p class="post-description">{description}</p>
          <hr />
        </div>
        <div class="prose" id="post-content">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<script>
  const btn = document.getElementById('translate-btn') as HTMLButtonElement;
  const content = document.getElementById('post-content');

  let translated = false;
  let originalHTML = '';
  let originalH1 = '';
  let originalDesc = '';

  function extractTextNodes(root: Node): Text[] {
    const nodes: Text[] = [];
    const skip = ['CODE', 'PRE', 'SVG', 'SCRIPT', 'STYLE'];

    function walk(node: Node) {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent?.trim();
        if (text && text.length > 2) nodes.push(node as Text);
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        if (skip.includes((node as Element).tagName)) return;
        for (const child of Array.from(node.childNodes)) walk(child);
      }
    }
    walk(root);
    return nodes;
  }

  function chunkText(texts: string[], maxLen = 480): string[][] {
    const chunks: string[][] = [];
    let current: string[] = [];
    let currentLen = 0;

    for (const text of texts) {
      if (currentLen + text.length > maxLen) {
        if (current.length) chunks.push(current);
        current = [text];
        currentLen = text.length;
      } else {
        current.push(text);
        currentLen += text.length;
      }
    }
    if (current.length) chunks.push(current);
    return chunks;
  }

  async function translateChunk(texts: string[]): Promise<string[]> {
    const joined = texts.join('\n||||\n');
    const res = await fetch(
      `https://api.mymemory.translated.net/get?q=${encodeURIComponent(joined)}&langpair=es|en&de=juanenlopez1459@gmail.com`
    );
    const data = await res.json();
    const result = data.responseData.translatedText as string;
    return result.split('\n||||\n');
  }

  btn?.addEventListener('click', async () => {
    if (!content) return;

    const h1 = document.querySelector('h1');
    const desc = document.querySelector('.post-description');

    if (!translated) {
      btn.textContent = '...';
      btn.disabled = true;

      originalHTML = content.innerHTML;
      originalH1 = h1?.textContent || '';
      originalDesc = desc?.textContent || '';

      try {
        const areas = [h1, desc, content].filter(Boolean) as Node[];
        const nodes = areas.flatMap(el => extractTextNodes(el));
        const texts = nodes.map(n => n.textContent || '');
        const chunks = chunkText(texts, 300);

        const results = await Promise.all(chunks.map(translateChunk));
        const flat = results.flat();

        nodes.forEach((node, i) => {
          if (flat[i]) node.textContent = flat[i];
        });

        btn.textContent = 'ES';
        btn.disabled = false;
        translated = true;
      } catch {
        content.innerHTML = originalHTML;
        if (h1) h1.textContent = originalH1;
        if (desc) desc.textContent = originalDesc;
        btn.textContent = 'EN';
        btn.disabled = false;
      }
    } else {
      content.innerHTML = originalHTML;
      if (h1) h1.textContent = originalH1;
      if (desc) desc.textContent = originalDesc;
      btn.textContent = 'EN';
      translated = false;
    }
  });
</script>

<style>
  article {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-date {
    font-size: 0.75rem;
    color: rgba(232,232,232,0.4);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .updated {
    font-style: italic;
  }

  h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .post-description {
    font-size: 0.95rem;
    color: rgba(232,232,232,0.5);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin: 1.5rem 0 2rem;
  }

  .prose {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  @media (max-width: 720px) {
    article { padding: 2rem 1.25rem; }
    h1 { font-size: 1.6rem; }
  }
</style>