---
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="logo">JELOPEZ<span>.</span>LINK</a>
    <div class="nav-links">
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">Sobre mí</HeaderLink>
      <a href="https://jelopez.link" target="_blank">← Web</a>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 2rem;
    background: rgba(8,8,8,0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    max-width: 900px;
    margin: 0 auto;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: #e8e8e8;
    text-decoration: none;
  }

  .logo span { color: #e03030; }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(232,232,232,0.5);
    text-decoration: none;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
    border-bottom: none;
    padding: 0;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: #e03030;
    border-bottom: none;
  }
</style>
